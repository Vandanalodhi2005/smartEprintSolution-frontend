{
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/step-by-step-setup-guide", "destination": "/step-by-step-setup-guide.html" },
    { "source": "/model-search", "destination": "/model-search.html" },
    { "source": "/complete-setup", "destination": "/complete-setup.html" },
    { "source": "/installation-failed", "destination": "/installation-failed.html" },
    { "source": "/admin/(.*)", "destination": "/index.html" },
    { "source": "/profile/(.*)", "destination": "/index.html" },
    { "source": "/cart/(.*)", "destination": "/index.html" },
    { "source": "/checkout/(.*)", "destination": "/index.html" },
    { "source": "/product/(.*)", "destination": "/index.html" },
    { "source": "/order/(.*)", "destination": "/index.html" },
    { "source": "/track-order/(.*)", "destination": "/index.html" },
    { "source": "/settings-management(.*)", "destination": "/index.html" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
